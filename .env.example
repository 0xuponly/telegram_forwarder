# Get API ID and API Hash from https://my.telegram.org
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here

# Channel 1 (or use TELEGRAM_FORWARD_TO + TELEGRAM_KEYWORDS)
TELEGRAM_FORWARD_TO_1=@channel1
TELEGRAM_KEYWORDS_1=dubai,uae,u.a.e.,abu dhabi,sharjah,fujairah

# Channel 2
# TELEGRAM_FORWARD_TO_2=@channel2
# TELEGRAM_KEYWORDS_2=qatar,qatari,doha,al wakrah,lusail,al khor,mesaieed,dukhan,al shamal,madinat ash shamal,al rayyan,umm salal muhammed,ras laffan,al ruwais,zekreet,katara

# Channel 3
# TELEGRAM_FORWARD_TO_3=@channel3
# TELEGRAM_KEYWORDS_3=another,comma,separated,list

# Optional: session file name (default: dubai_alerts_session)
# TELEGRAM_SESSION=dubai_alerts_session

# Optional: case-sensitive matching (default: false)
# TELEGRAM_CASE_INSENSITIVE=true
